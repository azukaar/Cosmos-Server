{
  "name": "cosmos-cloud-sdk",
  "version": "0.0.0",
  "description": "JavaScript/TypeScript SDK for the Cosmos Server API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "node -e \"const p=require('./package.json');const r=require('../package.json');p.version=r.version;require('fs').writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n')\" && npm run build"
  },
  "keywords": [
    "cosmos",
    "cosmos-server",
    "cosmos-cloud",
    "api",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/azukaar/Cosmos-Server.git",
    "directory": "sdk"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
